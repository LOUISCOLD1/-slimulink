# ============================================
# 复制这个文件为 .env，然后填入你的API Key
# cp .env.example .env
# ============================================

# 智谱AI（免费）- https://open.bigmodel.cn 注册获取
ZHIPU_API_KEY=your_zhipu_api_key_here

# DeepSeek（备选）- https://platform.deepseek.com 注册获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 讯飞语音（蒙古语）- https://www.xfyun.cn 注册获取
XFYUN_APP_ID=your_xfyun_app_id
XFYUN_API_KEY=your_xfyun_api_key

# 服务器配置
HOST=0.0.0.0
PORT=8000
