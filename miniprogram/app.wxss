/* 全局样式 */
page {
  background-color: #F3F4F6;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 32rpx;
  color: #1F2937;
}

/* 大字体，适合中老年用户 */
.text-lg { font-size: 36rpx; }
.text-xl { font-size: 40rpx; }
.text-2xl { font-size: 48rpx; }
.text-3xl { font-size: 56rpx; }
.text-bold { font-weight: bold; }
.text-center { text-align: center; }
.text-gray { color: #6B7280; }
.text-blue { color: #2563EB; }
.text-green { color: #059669; }
.text-white { color: #FFFFFF; }

/* 通用容器 */
.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 大按钮 */
.btn-primary {
  background: #2563EB;
  color: white;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  border: none;
}

.btn-primary:active {
  background: #1D4ED8;
}

.btn-green {
  background: #059669;
  color: white;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  border: none;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: #E5E7EB;
  margin: 24rpx 0;
}
