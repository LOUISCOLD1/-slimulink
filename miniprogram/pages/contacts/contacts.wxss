.page-title {
  margin-top: 20rpx;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.contact-card {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.contact-card:active {
  background: #F0FDF4;
}

.contact-info {
  flex: 1;
}

.contact-name {
  display: block;
  margin-bottom: 4rpx;
}

.contact-name-mn {
  display: block;
  font-size: 26rpx;
  margin-bottom: 4rpx;
}

.contact-desc {
  display: block;
  font-size: 26rpx;
}

.call-btn {
  background: #059669;
  color: white;
  padding: 20rpx 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.call-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.call-text {
  font-size: 32rpx;
  font-weight: bold;
}

.empty-state {
  text-align: center;
  padding: 80rpx;
  color: #9CA3AF;
  font-size: 32rpx;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 80rpx;
  color: #6B7280;
  font-size: 32rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #E5E7EB;
  border-top: 4rpx solid #2563EB;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
