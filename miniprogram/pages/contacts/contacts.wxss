.container { padding: 0 0 32rpx; }
.page-header { padding: 28rpx 28rpx 20rpx; }
.page-title { font-size: 40rpx; font-weight: 700; color: #064e3b; }
.page-subtitle { font-size: 24rpx; color: #6b7280; margin-top: 4rpx; }

.group-title {
  font-size: 26rpx; font-weight: 600; color: #064e3b;
  margin: 20rpx 28rpx 10rpx; padding-bottom: 8rpx;
  border-bottom: 2rpx solid #d1fae5;
}

.contact-card {
  display: flex; align-items: center; justify-content: space-between;
  background: #fff; margin: 0 24rpx 10rpx; border-radius: 16rpx;
  padding: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.contact-name { font-size: 30rpx; font-weight: 600; color: #1f2937; }
.contact-phone { font-size: 26rpx; color: #059669; margin-top: 4rpx; }

.contact-actions { display: flex; gap: 16rpx; align-items: center; }
.fav-btn {
  font-size: 36rpx; width: 60rpx; height: 60rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%; background: #f3f4f6;
}
.fav-active { background: #fef3c7; }
.call-btn {
  font-size: 32rpx; width: 80rpx; height: 60rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 12rpx; background: #059669; color: #fff;
}
.call-btn:active { opacity: 0.85; }

.empty-state { text-align: center; padding: 80rpx; color: #9ca3af; font-size: 28rpx; }

.loading-state {
  text-align: center;
  padding: 80rpx;
  color: #6b7280;
  font-size: 28rpx;
}
.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #e5e7eb;
  border-top: 4rpx solid #059669;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 16rpx;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
