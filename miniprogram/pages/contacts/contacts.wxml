<view class="container">
  <view class="page-header">
    <view class="page-title">{{lang === 'zh' ? '便民电话' : 'ᠠᠷᠠᠳ ᠤᠨ ᠤᠲᠠᠰᠤ'}}</view>
    <view class="page-subtitle">{{lang === 'zh' ? '点击即可直接拨打' : 'ᠳᠠᠷᠤᠪᠠᠯ ᠤᠲᠠᠰᠤᠳᠠᠬᠤ ᠪᠣᠯᠤᠨ᠎ᠠ'}}</view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
  </view>

  <view wx:if="{{!loading}}">
    <!-- 收藏区 -->
    <view wx:if="{{favoriteList.length > 0}}">
      <view class="group-title">⭐ {{lang === 'zh' ? '常用号码' : 'ᠪᠠᠢᠩᠭᠤ ᠤᠲᠠᠰᠤ'}}</view>
      <view class="contact-card" wx:for="{{favoriteList}}" wx:key="phone">
        <view class="contact-info">
          <view class="contact-name">{{item.name}}</view>
          <view class="contact-phone">{{item.phone}}</view>
        </view>
        <view class="contact-actions">
          <view class="fav-btn fav-active" bindtap="toggleFavorite" data-phone="{{item.phone}}">⭐</view>
          <view class="call-btn" bindtap="makeCall" data-phone="{{item.phone}}">📞</view>
        </view>
      </view>
    </view>

    <!-- 按类别分组 -->
    <block wx:for="{{groups}}" wx:key="category">
      <view class="group-title">{{item.category}}</view>
      <view class="contact-card" wx:for="{{item.contacts}}" wx:for-item="contact" wx:key="phone">
        <view class="contact-info">
          <view class="contact-name">{{contact.name}}</view>
          <view class="contact-phone">{{contact.phone}}</view>
        </view>
        <view class="contact-actions">
          <view class="fav-btn {{contact.isFav ? 'fav-active' : ''}}" bindtap="toggleFavorite" data-phone="{{contact.phone}}">{{contact.isFav ? '⭐' : '☆'}}</view>
          <view class="call-btn" bindtap="makeCall" data-phone="{{contact.phone}}">📞</view>
        </view>
      </view>
    </block>

    <view class="empty-state" wx:if="{{groups.length === 0 && favoriteList.length === 0}}">
      <text>{{lang === 'zh' ? '暂无联系电话' : 'ᠤᠲᠠᠰᠤ ᠪᠠᠢᠬᠤ ᠦᠭᠡᠢ'}}</text>
    </view>
  </view>
</view>
