<!-- 设置页 -->
<view class="container">

  <view class="page-title text-2xl text-bold text-center">⚙️ 设置</view>

  <!-- 语言设置 -->
  <view class="card">
    <view class="setting-title text-xl text-bold">🌐 语言 / ᠬᠡᠯᠡ</view>
    <view class="setting-options">
      <view
        class="option-btn {{lang === 'zh' ? 'option-active' : ''}}"
        bindtap="setLang"
        data-lang="zh"
      >中文</view>
      <view
        class="option-btn {{lang === 'mn' ? 'option-active' : ''}}"
        bindtap="setLang"
        data-lang="mn"
      >ᠮᠣᠩᠭᠣᠯ ᠬᠡᠯᠡ</view>
    </view>
  </view>

  <!-- AI引擎 -->
  <view class="card">
    <view class="setting-title text-xl text-bold">🤖 AI引擎</view>
    <view class="setting-options">
      <view
        class="option-btn {{engine === 'zhipu' ? 'option-active' : ''}}"
        bindtap="setEngine"
        data-engine="zhipu"
      >智谱（免费）</view>
      <view
        class="option-btn {{engine === 'deepseek' ? 'option-active' : ''}}"
        bindtap="setEngine"
        data-engine="deepseek"
      >DeepSeek</view>
    </view>
  </view>

  <!-- 服务器地址 -->
  <view class="card">
    <view class="setting-title text-xl text-bold">🖥️ 服务器地址</view>
    <input
      class="server-input"
      placeholder="http://your-server-ip:80"
      value="{{baseUrl}}"
      bindinput="onUrlInput"
      bindblur="saveUrl"
    />
    <view class="setting-hint text-gray">部署后端后填入服务器地址</view>
  </view>

  <!-- 关于 -->
  <view class="card about-card">
    <view class="setting-title text-xl text-bold">📱 关于牧智通</view>
    <view class="about-text text-gray">
      面向内蒙古农牧民的智能政策咨询助手。
      支持蒙汉双语语音问答，帮助牧民了解补贴、医保、低保等惠民政策。
    </view>
    <view class="about-text text-gray" style="margin-top: 16rpx;">
      版本 1.0.0
    </view>
  </view>

</view>
