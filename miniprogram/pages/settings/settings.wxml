<view class="page-root">
  <!-- 顶部导航栏：毛玻璃 -->
  <view class="top-bar-glass" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar">
      <view class="nav-back" bindtap="goBack">
        <text class="back-arrow">&#x2190;</text>
      </view>
      <text class="nav-title">系统设置</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <view style="height: {{statusBarHeight + 44}}px;"></view>

  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar">
      <text class="user-initial">牧</text>
    </view>
    <view class="user-info">
      <text class="user-name">牧民用户</text>
      <text class="user-id">Registry ID: NMG-2024-089231</text>
      <text class="user-switch">切换账户模式</text>
    </view>
  </view>

  <!-- 辅助功能 -->
  <view class="section-header">
    <view class="section-bar"></view>
    <text class="section-title">辅助功能</text>
  </view>

  <view class="settings-group">
    <!-- 字体大小 -->
    <view class="setting-row">
      <view class="setting-left">
        <text class="setting-label">字体大小</text>
        <text class="setting-value">标准</text>
      </view>
      <switch class="red-switch" checked="{{fontSizeOn}}" bindchange="onFontSizeToggle" color="#ce0000" />
    </view>

    <!-- 高对比度模式 -->
    <view class="setting-row">
      <view class="setting-left">
        <text class="setting-label">高对比度模式</text>
      </view>
      <switch class="red-switch" checked="{{highContrast}}" bindchange="onHighContrastToggle" color="#ce0000" />
    </view>

    <!-- 家属通知优先 -->
    <view class="setting-row">
      <view class="setting-left">
        <text class="setting-label">家属通知优先</text>
      </view>
      <switch class="red-switch" checked="{{familyNotify}}" bindchange="onFamilyNotifyToggle" color="#ce0000" />
    </view>

    <!-- 系统语言 -->
    <view class="setting-row">
      <view class="setting-left">
        <text class="setting-label">系统语言</text>
      </view>
      <text class="setting-lang-value">简体中文/蒙文</text>
    </view>
  </view>

  <!-- 更多选项 -->
  <view class="settings-group" style="margin-top: 24rpx;">
    <view class="setting-row setting-row-link" bindtap="onHelpTap">
      <text class="setting-label">帮助与支持</text>
      <text class="setting-chevron">&#x203A;</text>
    </view>
    <view class="setting-row setting-row-link" bindtap="onFeedbackTap">
      <text class="setting-label">意见反馈</text>
      <text class="setting-chevron">&#x203A;</text>
    </view>
  </view>

  <!-- 底部版本号 -->
  <view class="footer-text">SERVICE PORTAL V4231-2024.SECURE.REGISTRY</view>

  <!-- 底部留白 -->
  <view style="height: 160rpx;"></view>
</view>
