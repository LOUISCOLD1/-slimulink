.container { padding: 20rpx 0 40rpx; }
.page-title {
  font-size: 40rpx; font-weight: 700; color: #064e3b;
  padding: 8rpx 28rpx 24rpx;
}

.card {
  background: #fff; border-radius: 20rpx;
  padding: 28rpx; margin: 0 24rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.setting-label { font-size: 30rpx; font-weight: 600; color: #1f2937; margin-bottom: 16rpx; }

.option-group { display: flex; gap: 12rpx; flex-wrap: wrap; }
.option-btn {
  flex: 1; min-width: 0; text-align: center;
  padding: 16rpx 12rpx; border-radius: 12rpx;
  font-size: 26rpx; color: #6b7280;
  background: #f3f4f6; border: 2rpx solid transparent;
  transition: all 0.2s;
}
.option-active {
  background: #ecfdf5; color: #059669; font-weight: 600;
  border-color: #059669;
}

.clear-btn {
  text-align: center; padding: 20rpx; font-size: 30rpx;
  color: #dc2626; font-weight: 500;
  border: 2rpx solid #fecaca; border-radius: 12rpx;
}
.clear-btn:active { background: #fef2f2; }

.about-card { }
.about-text { font-size: 26rpx; color: #6b7280; line-height: 1.6; }
.about-version { font-size: 24rpx; color: #9ca3af; margin-top: 12rpx; }
