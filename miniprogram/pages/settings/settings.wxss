.page-title {
  margin-top: 20rpx;
  margin-bottom: 32rpx;
}

.setting-title {
  margin-bottom: 20rpx;
}

.setting-options {
  display: flex;
  gap: 16rpx;
}

.option-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #F3F4F6;
  font-size: 32rpx;
  color: #4B5563;
}

.option-active {
  background: #2563EB;
  color: white;
  font-weight: bold;
}

.server-input {
  background: #F3F4F6;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  margin-bottom: 8rpx;
}

.setting-hint {
  font-size: 24rpx;
}

.about-card {
  margin-top: 20rpx;
}

.about-text {
  font-size: 28rpx;
  line-height: 1.6;
}
