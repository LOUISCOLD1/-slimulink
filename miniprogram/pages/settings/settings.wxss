.page-root {
  min-height: 100vh;
  background: var(--surface);
}

/* ===== 毛玻璃顶部栏 ===== */
.top-bar-glass {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 999;
  background: var(--glass-bg);
  -webkit-backdrop-filter: var(--glass-blur);
  backdrop-filter: var(--glass-blur);
}
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}
.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-arrow {
  font-size: 40rpx;
  color: var(--on-surface);
  font-weight: 300;
}
.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--on-surface);
}
.nav-placeholder {
  width: 64rpx;
}

/* ===== 用户卡片 ===== */
.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 36rpx 28rpx;
  margin: 16rpx 24rpx 0;
  background: var(--surface-container-lowest);
  border-radius: 28rpx;
  box-shadow: var(--shadow-card);
}
.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--on-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.user-initial {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}
.user-info {
  display: flex;
  flex-direction: column;
}
.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--on-surface);
  margin-bottom: 4rpx;
}
.user-id {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}
.user-switch {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
}

/* ===== 辅助功能 Section Header ===== */
.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 36rpx 28rpx 16rpx;
}
.section-bar {
  width: 8rpx;
  height: 32rpx;
  border-radius: 4rpx;
  background: var(--primary);
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--on-surface);
}

/* ===== 设置行组 ===== */
.settings-group {
  margin: 0 24rpx;
  background: var(--surface-container-lowest);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  min-height: 96rpx;
  box-sizing: border-box;
}
/* 行之间的视觉分隔：用背景色差替代边框 */
.setting-row + .setting-row {
  background: linear-gradient(to bottom, var(--surface-container-low) 0, var(--surface-container-low) 1rpx, var(--surface-container-lowest) 1rpx);
}

.setting-left {
  display: flex;
  flex-direction: column;
}
.setting-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--on-surface);
}
.setting-value {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}
.setting-lang-value {
  font-size: 26rpx;
  color: var(--on-surface-variant);
}

/* switch 红色已通过 color 属性设置 */
.red-switch {
  transform: scale(0.85);
}

/* 链接行 */
.setting-row-link {
  transition: background 0.2s;
}
.setting-row-link:active {
  background: var(--surface-container-low);
}
.setting-chevron {
  font-size: 36rpx;
  color: var(--text-muted);
  font-weight: 300;
}

/* ===== 底部版本文字 ===== */
.footer-text {
  text-align: center;
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 48rpx;
  letter-spacing: 2rpx;
}
