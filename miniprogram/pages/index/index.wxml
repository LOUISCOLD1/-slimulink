<view class="container">
  <!-- Banner -->
  <view class="banner">
    <view class="banner-title">牧民政策助手</view>
    <view class="banner-mn">ᠮᠠᠯᠴᠢᠨ ᠤ ᠲᠥᠷᠥ ᠵᠢᠷᠤᠮ ᠤᠨ ᠲᠤᠰᠠᠯᠠᠭᠴᠢ</view>
    <view class="banner-sub">{{lang === 'zh' ? '开口就能问政策' : 'ᠠᠮᠠ ᠨᠡᠭᠡᠭᠡᠪᠡᠯ ᠲᠥᠷᠥ ᠵᠢᠷᠤᠮ ᠠᠰᠠᠭᠤᠵᠤ ᠪᠣᠯᠤᠨ᠎ᠠ'}}</view>
    <view class="banner-wave"></view>
  </view>

  <!-- 对话列表入口 -->
  <view class="chat-list-entry" bindtap="goToChatList" wx:if="{{chatCount > 0}}">
    <text>📝 {{lang === 'zh' ? '查看历史对话' : 'ᠶᠠᠷᠢᠯᠴᠠᠯᠭ᠎ᠠ ᠦᠵᠡᠬᠦ'}} ({{chatCount}})</text>
    <text class="entry-arrow">›</text>
  </view>

  <!-- 提醒条 -->
  <view class="remind-bar" wx:if="{{reminder}}" bindtap="onReminderTap">
    <text class="remind-icon">📢</text>
    <text class="remind-text">{{reminder}}</text>
    <text class="remind-arrow">›</text>
  </view>

  <!-- 语音卡片 -->
  <view class="voice-card">
    <view class="voice-title">{{lang === 'zh' ? '想了解什么政策？' : 'ᠶᠠᠭᠤ ᠠᠰᠠᠭᠤᠬᠤ ᠪᠤᠢ?'}}</view>
    <view class="mic-btn {{isRecording ? 'mic-recording' : ''}}" bindtap="onMicTap">
      <text class="mic-icon">🎙️</text>
    </view>
    <view class="mic-label" wx:if="{{!isRecording}}">{{lang === 'zh' ? '点击说话' : 'ᠳᠠᠷᠤᠵᠤ ᠶᠠᠷᠢ'}}</view>
    <view class="mic-label mic-label-active" wx:else>{{lang === 'zh' ? '点击停止' : 'ᠳᠠᠷᠤᠵᠤ ᠵᠣᠭᠰᠣᠬᠤ'}}</view>
  </view>

  <!-- 文字输入 -->
  <view class="input-row">
    <input class="text-input" placeholder="{{lang === 'zh' ? '也可以打字提问...' : 'ᠠᠰᠠᠭᠤᠯᠲᠠ ᠪᠢᠴᠢᠬᠦ...'}}" value="{{inputText}}" bindinput="onInput" bindconfirm="onTextSubmit" disabled="{{isLoading}}" />
    <view class="send-btn" bindtap="onTextSubmit" wx:if="{{inputText && !isLoading}}">
      {{lang === 'zh' ? '发送' : 'ᠢᠯᠡᠭᠡᠬᠦ'}}
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-bar" wx:if="{{isLoading}}">
    <view class="loading-spinner-small"></view>
    <text>{{lang === 'zh' ? '正在查询政策...' : 'ᠲᠥᠷᠥ ᠵᠢᠷᠤᠮ ᠬᠠᠢᠵᠤ ᠪᠠᠢᠨ᠎ᠠ...'}}</text>
  </view>

  <!-- 热门问题 -->
  <view class="hot-section">
    <view class="hot-title">🔥 {{lang === 'zh' ? '热门问题' : 'ᠬᠠᠯᠠᠭᠤᠨ ᠠᠰᠠᠭᠤᠯᠲᠠ'}}</view>
    <view class="hot-item" wx:for="{{hotQuestions}}" wx:key="index"
      bindtap="onHotQuestion" data-question="{{lang === 'zh' ? item.zh : item.mn}}">
      <text class="hot-icon">{{item.icon}}</text>
      <text class="hot-text">{{lang === 'zh' ? item.zh : item.mn}}</text>
    </view>
  </view>
</view>
