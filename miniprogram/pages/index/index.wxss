.page-root {
  min-height: 100vh;
  background: var(--surface);
}

/* ===== 顶部导航栏 ===== */
.top-bar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 999;
  background: var(--primary);
}
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}
.nav-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.nav-location-icon {
  font-size: 28rpx;
}
.nav-location-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}
.nav-center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}
.nav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 1rpx;
}

/* ===== 滚动区域 ===== */
.scroll-body {
  height: calc(100vh - 88rpx);
}

/* ===== 英雄横幅 ===== */
.hero-banner {
  margin: 24rpx 24rpx 0;
  border-radius: 24rpx;
  height: 384rpx;
  background: linear-gradient(135deg, #a00000 0%, #ce0000 40%, #800000 100%);
  position: relative;
  overflow: hidden;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.hero-gradient-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(0,0,0,0.45), transparent);
  pointer-events: none;
}
.hero-badge {
  position: relative;
  z-index: 2;
  display: inline-block;
  background: var(--secondary-container);
  color: var(--secondary);
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  align-self: flex-start;
}
.hero-title {
  position: relative;
  z-index: 2;
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.35;
  margin-bottom: 12rpx;
}
.hero-sub {
  position: relative;
  z-index: 2;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ===== 快捷入口 2列网格 ===== */
.quick-grid {
  display: flex;
  gap: 20rpx;
  margin: 24rpx 24rpx 0;
}
.quick-item {
  flex: 1;
  background: var(--surface-container-lowest);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: var(--shadow-card);
  min-height: 96rpx;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s;
}
.quick-item:active {
  transform: scale(0.97);
}
/* 金色底部装饰线 */
.quick-item-gold::after {
  content: '';
  position: absolute;
  bottom: 0; left: 24rpx; right: 24rpx;
  height: 4rpx;
  background: var(--secondary-container);
  border-radius: 2rpx;
}
/* 红色底部装饰线 */
.quick-item-red::after {
  content: '';
  position: absolute;
  bottom: 0; left: 24rpx; right: 24rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}
.quick-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}
.quick-text-wrap {
  display: flex;
  flex-direction: column;
}
.quick-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--on-surface);
}
.quick-desc {
  font-size: 22rpx;
  color: var(--on-surface-variant);
  margin-top: 4rpx;
}

/* ===== AI 政务顾问卡片 ===== */
.ai-card {
  margin: 24rpx 24rpx 0;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #a00000, #ce0000, #800000);
  padding: 36rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  transition: transform 0.2s;
}
.ai-card:active {
  transform: scale(0.98);
}
.ai-card-left {
  display: flex;
  flex-direction: column;
}
.ai-robot-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}
.ai-service-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.55);
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}
.ai-card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 6rpx;
}
.ai-card-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}
.ai-card-right {
  flex-shrink: 0;
}
.ai-arrow-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ai-arrow {
  font-size: 40rpx;
  color: var(--primary);
  font-weight: 700;
}

/* ===== 最新政策流 ===== */
.policy-stream-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 36rpx 28rpx 20rpx;
}
.policy-stream-bar {
  width: 8rpx;
  height: 36rpx;
  border-radius: 4rpx;
  background: var(--primary);
}
.policy-stream-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--on-surface);
}

.policy-stream-card {
  margin: 0 24rpx 16rpx;
  padding: 24rpx 28rpx;
  background: var(--surface-container-low);
  border-radius: 20rpx;
  position: relative;
  transition: transform 0.2s;
}
.policy-stream-card:active {
  transform: scale(0.98);
}
/* 左侧4rpx红色边 */
.policy-border-red {
  border-left: 8rpx solid var(--primary);
}
/* 左侧4rpx金色边 */
.policy-border-gold {
  border-left: 8rpx solid var(--secondary-container);
}
.policy-dept-badge {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 600;
  background: rgba(160, 0, 0, 0.08);
  color: var(--primary);
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 8rpx;
}
.badge-gold {
  background: rgba(112, 93, 0, 0.08);
  color: var(--secondary);
}
.policy-card-date {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}
.policy-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--on-surface);
  line-height: 1.4;
  margin-bottom: 8rpx;
}
.policy-card-desc {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  line-height: 1.5;
}

/* ===== FAB 浮动按钮 ===== */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--primary-vibrant);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(206, 0, 0, 0.35);
  z-index: 100;
  transition: transform 0.2s;
}
.fab:active {
  transform: scale(0.9);
}
.fab-icon {
  font-size: 48rpx;
  color: #ffffff;
}
