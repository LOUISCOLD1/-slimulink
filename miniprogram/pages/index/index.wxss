/* 首页样式 */

.reminder-card {
  background: #FEF3C7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.reminder-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.reminder-text {
  font-size: 30rpx;
  color: #92400E;
  flex: 1;
}

/* 语言切换 */
.lang-switch {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
  background: #E5E7EB;
  border-radius: 12rpx;
  padding: 4rpx;
}

.lang-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 10rpx;
  font-size: 32rpx;
  color: #6B7280;
  transition: all 0.2s;
}

.lang-active {
  background: #2563EB;
  color: white;
  font-weight: bold;
}

/* 问答区域 */
.qa-section {
  background: white;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.qa-title {
  margin-bottom: 12rpx;
}

.qa-subtitle {
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

/* 文字输入 */
.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.text-input {
  flex: 1;
  background: #F3F4F6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 32rpx;
}

.send-btn {
  background: #2563EB;
  color: white;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  margin-left: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
}

/* 录音按钮 */
.record-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.record-btn {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2563EB, #1D4ED8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.4);
  transition: all 0.2s;
}

.record-btn:active, .record-btn.recording {
  transform: scale(1.1);
  background: linear-gradient(135deg, #DC2626, #B91C1C);
  box-shadow: 0 8rpx 32rpx rgba(220, 38, 38, 0.4);
}

.record-icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.record-text {
  color: white;
  font-size: 28rpx;
  font-weight: bold;
}

.record-hint {
  margin-top: 16rpx;
  font-size: 26rpx;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 加载状态 */
.loading-card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #E5E7EB;
  border-top: 4rpx solid #2563EB;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  color: #6B7280;
}

/* 热门问题 */
.hot-section {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  margin-bottom: 24rpx;
}

.hot-item {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  border-bottom: 2rpx solid #F3F4F6;
}

.hot-item:last-child {
  border-bottom: none;
}

.hot-item:active {
  background: #F3F4F6;
  border-radius: 12rpx;
}

.hot-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.hot-text {
  font-size: 34rpx;
  flex: 1;
}
