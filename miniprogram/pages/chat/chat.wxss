.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--surface);
}

.msg-list {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

.msg-wrapper { margin-bottom: 32rpx; }

/* ===== 用户消息：右对齐 ===== */
.msg-user {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.bubble-user {
  background: var(--surface-container-high);
  color: var(--on-surface);
  padding: 24rpx 28rpx;
  /* 圆角：上方全圆，右上角方角 */
  border-radius: 28rpx 4rpx 28rpx 28rpx;
  font-size: 30rpx;
  max-width: 75%;
  line-height: 1.6;
  word-break: break-all;
}
.msg-time-right {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  margin-right: 4rpx;
}

/* ===== AI 消息：左对齐 ===== */
.msg-bot {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

/* 官方权威解读徽章 */
.official-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  background: rgba(252, 212, 0, 0.1);
  margin-bottom: 12rpx;
}
.badge-icon {
  font-size: 24rpx;
  color: var(--secondary);
}
.badge-text {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--secondary);
}

.bubble-bot {
  background: var(--surface-container-lowest);
  color: var(--on-surface);
  padding: 28rpx 28rpx;
  /* 圆角：上方全圆，左上角方角 */
  border-radius: 4rpx 28rpx 28rpx 28rpx;
  font-size: 30rpx;
  max-width: 85%;
  line-height: 1.7;
  word-break: break-all;
  /* 左侧红色边框 */
  border-left: 8rpx solid var(--primary);
  box-shadow: var(--shadow-card);
}

/* 操作按钮行 */
.bot-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 16rpx;
}
.action-link {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
}
.action-icons {
  display: flex;
  gap: 24rpx;
}
.icon-btn {
  font-size: 32rpx;
  color: var(--on-surface-variant);
  padding: 8rpx;
}

/* 来源 */
.bot-source {
  margin-top: 16rpx;
  padding-top: 12rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}
.source-label { margin-right: 8rpx; }
.source-name {
  display: inline;
  margin-right: 12rpx;
}

/* ===== 思考中动画 ===== */
.thinking { padding: 28rpx 40rpx; }
.thinking-dots {
  display: flex;
  gap: 12rpx;
  align-items: center;
}
.dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  background: var(--primary);
  animation: bounce 1.4s infinite ease-in-out both;
}
.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.4); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* ===== 建议词条滚动行 ===== */
.suggestion-bar {
  position: fixed;
  bottom: 120rpx;
  left: 0; right: 0;
  z-index: 99;
  padding: 0 24rpx;
  padding-bottom: 12rpx;
}
.suggestion-scroll {
  white-space: nowrap;
}
.suggestion-chip {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin-right: 16rpx;
  background: var(--surface-container-lowest);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: var(--on-surface-variant);
  box-shadow: var(--shadow-card);
  transition: all 0.2s;
}
.suggestion-chip:active {
  background: var(--surface-container-high);
  transform: scale(0.96);
}

/* ===== 底部输入栏 ===== */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  gap: 12rpx;
  background: var(--glass-bg);
  -webkit-backdrop-filter: var(--glass-blur);
  backdrop-filter: var(--glass-blur);
  position: fixed;
  bottom: 0;
  left: 0; right: 0;
  z-index: 100;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-add-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--surface-container);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.add-icon {
  font-size: 40rpx;
  color: var(--on-surface-variant);
  font-weight: 300;
}

.input-field {
  flex: 1;
  background: var(--surface-container-lowest);
  border-radius: 32rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  color: var(--on-surface);
  min-height: 96rpx;
  box-sizing: border-box;
}
/* 聚焦时底部金色线 — 用伪类模拟（input 不支持 :focus 伪类，改用 JS class） */
.input-field-focus {
  box-shadow: inset 0 -4rpx 0 0 var(--secondary-container);
}

.input-mic {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--surface-container);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  transition: all 0.3s;
}
.mic-text { font-size: 32rpx; }
.mic-active {
  background: var(--primary-vibrant);
  animation: pulse-small 1.5s ease-in-out infinite;
}
@keyframes pulse-small {
  0%, 100% { box-shadow: 0 0 0 4rpx rgba(206, 0, 0, 0.2); }
  50% { box-shadow: 0 0 0 16rpx rgba(206, 0, 0, 0.1); }
}

.input-send-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--primary-vibrant);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: transform 0.2s;
}
.input-send-btn:active {
  transform: scale(0.9);
}
.send-arrow {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 700;
}
