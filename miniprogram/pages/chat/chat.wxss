.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0fdf4;
}

.msg-list {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

.msg-wrapper { margin-bottom: 24rpx; }

/* 用户消息 */
.msg-user {
  display: flex;
  justify-content: flex-end;
}
.bubble-user {
  background: linear-gradient(135deg, #059669, #047857);
  color: #fff;
  padding: 20rpx 28rpx;
  border-radius: 24rpx 24rpx 4rpx 24rpx;
  font-size: 30rpx;
  max-width: 75%;
  line-height: 1.6;
  word-break: break-all;
  /* 内阴影增加深度感 */
  box-shadow: inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.1), 0 4rpx 12rpx rgba(5, 150, 105, 0.2);
}

/* AI消息 */
.msg-bot {
  display: flex;
  justify-content: flex-start;
  gap: 12rpx;
}
.bot-avatar {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: #064e3b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
  /* 金色光环边框 */
  border: 2rpx solid rgba(251, 191, 36, 0.4);
  box-shadow: 0 0 0 3rpx rgba(251, 191, 36, 0.15);
}
.bubble-bot {
  background: #fff;
  color: #1f2937;
  padding: 24rpx 28rpx;
  border-radius: 24rpx 24rpx 24rpx 4rpx;
  font-size: 30rpx;
  max-width: 80%;
  line-height: 1.7;
  /* 左侧金色细边 + 层次阴影 */
  border-left: 2rpx solid rgba(251, 191, 36, 0.3);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06), 0 8rpx 20rpx rgba(0, 0, 0, 0.03);
  word-break: break-all;
}

/* 操作按钮 */
.bot-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}
.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}
.play-btn {
  /* 药丸形播放按钮，带微妙渐变 */
  background: linear-gradient(135deg, #ecfdf5, #d1fae5);
  color: #059669;
  border-radius: 32rpx;
  padding: 10rpx 28rpx;
  box-shadow: 0 2rpx 6rpx rgba(5, 150, 105, 0.12);
}
.play-btn:active {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
  transform: scale(0.96);
}

/* 来源 */
.bot-source {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid #f0f0f0;
  font-size: 22rpx;
  color: #9ca3af;
}
.source-label { margin-right: 8rpx; }
.source-name {
  display: inline;
  margin-right: 12rpx;
}

/* 思考中动画 — 金色圆点增加视觉趣味 */
.thinking { padding: 24rpx 36rpx; }
.thinking-dots {
  display: flex;
  gap: 10rpx;
  align-items: center;
}
.dot {
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: #fbbf24;
  animation: bounce 1.4s infinite ease-in-out both;
  box-shadow: 0 0 6rpx rgba(251, 191, 36, 0.3);
}
.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.4); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* 底部输入栏 — 毛玻璃效果（渐进增强） */
.input-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.85);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(209, 250, 229, 0.6);
  position: fixed;
  bottom: 0;
  left: 0; right: 0;
  z-index: 100;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.input-field {
  flex: 1;
  background: rgba(240, 253, 244, 0.8);
  border: 2rpx solid #d1fae5;
  border-radius: 32rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
  color: #1f2937;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.04);
}
.input-mic {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #059669, #047857);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 12rpx rgba(5, 150, 105, 0.3);
}
.input-mic:active { transform: scale(0.9); }
.mic-active {
  background: linear-gradient(135deg, #dc2626, #ef4444);
  animation: pulse-small 1.5s ease-in-out infinite;
}
@keyframes pulse-small {
  0%, 100% { box-shadow: 0 0 0 4rpx rgba(239, 68, 68, 0.2); }
  50% { box-shadow: 0 0 0 12rpx rgba(239, 68, 68, 0.1); }
}
