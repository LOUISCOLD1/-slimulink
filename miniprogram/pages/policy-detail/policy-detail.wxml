<view class="container">
  <view class="card title-card">
    <text class="title-zh">{{policy.title_zh}}</text>
    <text class="title-mn" wx:if="{{policy.title_mn}}">{{policy.title_mn}}</text>
  </view>

  <view class="card money-card" wx:if="{{policy.money}}">
    <text class="card-label">{{lang === 'mn' ? '💰 ᠨᠥᠬᠥᠪᠥᠷᠢ ᠶᠢᠨ ᠪᠠᠷᠢᠮᠵᠢᠶ᠎ᠠ' : '💰 补贴标准'}}</text>
    <text class="money-amount">{{policy.money}}</text>
  </view>

  <view class="card" wx:if="{{policy.materials && policy.materials.length > 0}}">
    <text class="card-label">{{lang === 'mn' ? '📋 ᠬᠡᠷᠡᠭᠲᠡᠢ ᠮᠠᠲ᠋ᠧᠷᠢᠶᠠᠯ' : '📋 需要带的材料'}}</text>
    <view class="material-item" wx:for="{{policy.materials}}" wx:key="index">
      <text class="check-icon">✅</text>
      <text>{{item}}</text>
    </view>
  </view>

  <view class="card" wx:if="{{policy.steps && policy.steps.length > 0}}">
    <text class="card-label">{{lang === 'mn' ? '📝 ᠭᠦᠢᠴᠡᠳᠭᠡᠬᠦ ᠠᠯᠬᠠᠮ' : '📝 办理步骤'}}</text>
    <view class="step-item" wx:for="{{policy.steps}}" wx:key="index">
      <view class="step-num">{{index + 1}}</view>
      <text>{{item}}</text>
    </view>
  </view>

  <view class="card" wx:if="{{policy.where}}">
    <text class="card-label">{{lang === 'mn' ? '📍 ᠬᠠᠮᠢᠭ᠎ᠠ ᠭᠦᠢᠴᠡᠳᠭᠡᠬᠦ' : '📍 去哪办'}}</text>
    <text class="where-text">{{policy.where}}</text>
  </view>

  <view class="btn-row">
    <view class="btn-green phone-btn" bindtap="makeCall" wx:if="{{policy.phone}}">
      📞 {{lang === 'mn' ? 'ᠵᠥᠪᠯᠡᠯᠭᠡ ᠶᠢᠨ ᠤᠲᠠᠰᠤ' : '一键拨打咨询电话'}}
    </view>
    <view class="btn-outline ask-btn" bindtap="askAboutPolicy">
      🎙️ {{lang === 'mn' ? 'ᠡᠨᠡ ᠲᠥᠷᠥ ᠵᠢᠷᠤᠮ ᠤᠨ ᠲᠤᠬᠠᠢ ᠠᠰᠠᠭᠤᠬᠤ' : '关于这个政策，我还想问...'}}
    </view>
  </view>
</view>
