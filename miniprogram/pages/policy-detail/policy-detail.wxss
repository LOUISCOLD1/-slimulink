.container { padding: 20rpx 0 40rpx; }
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.title-card { background: linear-gradient(135deg, #064e3b, #047857); }
.title-zh { font-size: 40rpx; font-weight: 700; color: #fbbf24; display: block; }
.title-mn { font-size: 26rpx; color: #d1fae5; margin-top: 8rpx; display: block; }

.card-label { font-size: 30rpx; font-weight: 700; color: #064e3b; display: block; margin-bottom: 16rpx; }

.money-card { background: linear-gradient(135deg, #fffbeb, #fef3c7); border: 2rpx solid #fcd34d; }
.money-card .card-label { color: #92400e; }
.money-amount { font-size: 44rpx; font-weight: 700; color: #92400e; display: block; }

.material-item {
  display: flex; align-items: center; gap: 12rpx;
  padding: 10rpx 0; font-size: 30rpx; color: #1f2937;
}
.check-icon { font-size: 28rpx; }

.step-item {
  display: flex; align-items: flex-start; gap: 16rpx;
  padding: 12rpx 0; font-size: 30rpx; color: #1f2937;
}
.step-num {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #059669; color: #fff; font-size: 24rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}

.where-text { font-size: 30rpx; color: #1f2937; }

.btn-row { margin: 24rpx 24rpx 0; display: flex; flex-direction: column; gap: 16rpx; }
.phone-btn {
  background: linear-gradient(135deg, #059669, #047857);
  color: #fff; border-radius: 16rpx; padding: 28rpx;
  font-size: 32rpx; font-weight: 600; text-align: center;
}
.phone-btn:active { opacity: 0.85; }
.btn-outline {
  background: #fff; border: 3rpx solid #059669; color: #059669;
  border-radius: 16rpx; padding: 28rpx;
  font-size: 30rpx; font-weight: 600; text-align: center;
}
.btn-outline:active { background: #ecfdf5; }
