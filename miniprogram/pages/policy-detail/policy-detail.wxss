/* 政策详情 — 红金政务主题 */
.container { padding: 20rpx 0 40rpx; background: var(--surface); }
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(26,28,28,0.04);
}

/* 标题卡片：红色渐变 */
.title-card {
  background: linear-gradient(135deg, #a00000, #ce0000);
  position: relative;
  overflow: hidden;
}
.title-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: repeating-linear-gradient(
    45deg, transparent, transparent 20rpx,
    rgba(255,255,255,0.03) 20rpx, rgba(255,255,255,0.03) 40rpx
  );
  pointer-events: none;
}
.title-zh {
  font-size: 40rpx; font-weight: 700; color: #fff; display: block;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
  position: relative;
}
.title-mn {
  font-size: 26rpx; color: #ffdcd7; margin-top: 8rpx; display: block;
  position: relative;
}

.card-label { font-size: 30rpx; font-weight: 700; color: #1a1c1c; display: block; margin-bottom: 16rpx; }

/* 金额卡片 */
.money-card {
  background: linear-gradient(135deg, #fffbeb, #fef3c7);
  border: 2rpx solid #fcd400;
  position: relative; overflow: hidden;
}
.money-card .card-label { color: #705d00; }
.money-amount { font-size: 44rpx; font-weight: 700; color: #705d00; display: block; }
.money-card::after {
  content: '';
  position: absolute;
  top: -20rpx; right: -20rpx;
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(252,212,0,0.25);
  background: rgba(252,212,0,0.06);
}

.material-item {
  display: flex; align-items: center; gap: 12rpx;
  padding: 12rpx 0; font-size: 30rpx; color: #1a1c1c;
}
.check-icon { font-size: 28rpx; }

.step-item {
  display: flex; align-items: flex-start; gap: 16rpx;
  padding: 14rpx 0; font-size: 30rpx; color: #1a1c1c;
}
.step-num {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: linear-gradient(135deg, #a00000, #ce0000);
  color: #fff; font-size: 24rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  box-shadow: 0 3rpx 0 #7f0000, 0 4rpx 12rpx rgba(160,0,0,0.25);
}

.where-text { font-size: 30rpx; color: #1a1c1c; }

.btn-row { margin: 28rpx 24rpx 0; display: flex; flex-direction: column; gap: 16rpx; }
.phone-btn {
  background: linear-gradient(135deg, #a00000, #ce0000);
  color: #fff; border-radius: 16rpx; padding: 28rpx;
  font-size: 32rpx; font-weight: 600; text-align: center;
  box-shadow: 0 4rpx 0 #7f0000, 0 6rpx 16rpx rgba(160,0,0,0.3);
  transition: all 0.15s;
}
.phone-btn:active {
  transform: translateY(3rpx);
  box-shadow: 0 1rpx 0 #7f0000, 0 2rpx 8rpx rgba(160,0,0,0.2);
}
.btn-outline {
  background: #fff; border: 3rpx solid #a00000; color: #a00000;
  border-radius: 16rpx; padding: 28rpx;
  font-size: 30rpx; font-weight: 600; text-align: center;
  transition: all 0.2s;
}
.btn-outline:active { background: #ffdad4; transform: scale(0.98); }
