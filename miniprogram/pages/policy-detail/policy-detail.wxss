.container { padding: 20rpx 0 40rpx; }
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06), 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}
.title-card {
  background: linear-gradient(135deg, #064e3b, #047857);
  position: relative;
  overflow: hidden;
}
/* 标题卡片上的微妙纹理叠加 */
.title-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 20rpx,
    rgba(255, 255, 255, 0.015) 20rpx,
    rgba(255, 255, 255, 0.015) 40rpx
  );
  pointer-events: none;
}
.title-zh {
  font-size: 40rpx; font-weight: 700; color: #fbbf24; display: block;
  text-shadow: 0 2rpx 8rpx rgba(251, 191, 36, 0.3);
  position: relative;
}
.title-mn {
  font-size: 26rpx; color: #d1fae5; margin-top: 8rpx; display: block;
  position: relative;
}

.card-label { font-size: 30rpx; font-weight: 700; color: #064e3b; display: block; margin-bottom: 16rpx; }

.money-card {
  background: linear-gradient(135deg, #fffbeb, #fef3c7);
  border: 2rpx solid #fcd34d;
  position: relative;
  overflow: hidden;
}
.money-card .card-label { color: #92400e; }
.money-amount { font-size: 44rpx; font-weight: 700; color: #92400e; display: block; }
/* 金额卡片右上角的装饰性硬币圆形 */
.money-card::after {
  content: '';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(251, 191, 36, 0.25);
  background: rgba(251, 191, 36, 0.06);
}

.material-item {
  display: flex; align-items: center; gap: 12rpx;
  padding: 10rpx 0; font-size: 30rpx; color: #1f2937;
}
.check-icon { font-size: 28rpx; }

.step-item {
  display: flex; align-items: flex-start; gap: 16rpx;
  padding: 12rpx 0; font-size: 30rpx; color: #1f2937;
}
.step-num {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: linear-gradient(135deg, #059669, #047857);
  color: #fff; font-size: 24rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  /* 步骤编号的立体阴影 */
  box-shadow: 0 3rpx 0 #065f46, 0 4rpx 12rpx rgba(5, 150, 105, 0.25);
}

.where-text { font-size: 30rpx; color: #1f2937; }

.btn-row { margin: 24rpx 24rpx 0; display: flex; flex-direction: column; gap: 16rpx; }
.phone-btn {
  background: linear-gradient(135deg, #059669, #047857);
  color: #fff; border-radius: 16rpx; padding: 28rpx;
  font-size: 32rpx; font-weight: 600; text-align: center;
  /* 3D按钮效果 — 层叠阴影 */
  box-shadow: 0 4rpx 0 #065f46, 0 6rpx 16rpx rgba(5, 150, 105, 0.3);
  transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
}
.phone-btn:active {
  opacity: 0.9;
  transform: translateY(3rpx);
  box-shadow: 0 1rpx 0 #065f46, 0 2rpx 8rpx rgba(5, 150, 105, 0.2);
}
.btn-outline {
  background: #fff; border: 3rpx solid #059669; color: #059669;
  border-radius: 16rpx; padding: 28rpx;
  font-size: 30rpx; font-weight: 600; text-align: center;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}
.btn-outline:active {
  background: #ecfdf5;
  transform: scale(0.98);
}
