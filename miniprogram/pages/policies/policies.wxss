/* 政策库 — 红金政务主题 */
.container { padding: 0 0 32rpx; background: var(--surface); }

.search-bar {
  margin: 16rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 24rpx rgba(26,28,28,0.04);
  border-bottom: 3rpx solid transparent;
  transition: border-color 0.2s;
}
.search-bar:focus-within { border-bottom-color: var(--gold-accent); }
.search-icon { font-size: 28rpx; color: var(--text-muted); }
.search-input { flex: 1; font-size: 28rpx; color: var(--text-primary); }

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(26,28,28,0.04);
}
.cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 0;
  transition: transform 0.2s;
}
.cat-item:active { transform: scale(0.92); }
.cat-icon {
  width: 80rpx; height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.cat-name { font-size: 22rpx; color: #1a1c1c; font-weight: 500; }

/* 分类图标配色保持不变 */
.cat-gold { background: linear-gradient(135deg, #fef3c7, #fde68a); }
.cat-blue { background: linear-gradient(135deg, #dbeafe, #bfdbfe); }
.cat-purple { background: linear-gradient(135deg, #ede9fe, #ddd6fe); }
.cat-green { background: linear-gradient(135deg, #d1fae5, #a7f3d0); }
.cat-pink { background: linear-gradient(135deg, #ffe4e6, #fecdd3); }
.cat-sky { background: linear-gradient(135deg, #e0f2fe, #bae6fd); }
.cat-rose { background: linear-gradient(135deg, #fce7f3, #fbcfe8); }
.cat-gray { background: #f3f3f3; }

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 12rpx 28rpx 16rpx;
}
.section-title {
  font-size: 30rpx; font-weight: 700; color: #1a1c1c;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
/* 红色竖条装饰 */
.section-bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 4rpx;
  background: var(--primary);
}
.section-more { font-size: 24rpx; color: var(--primary); font-weight: 600; }

.policy-card {
  background: #f3f3f3;
  margin: 0 24rpx 12rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  border-left: 6rpx solid var(--primary);
  transition: all 0.2s;
}
.policy-card:active {
  background: #eeeeee;
  transform: scale(0.99);
}
.policy-card-gold { border-left-color: var(--gold-accent); }
.pc-badge {
  display: inline-block;
  background: #fff;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}
.pc-badge-red { color: var(--primary); }
.pc-badge-gold { color: #705d00; }
.pc-date { font-size: 20rpx; color: #5e3f3a; }
.pc-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10rpx; }
.pc-title { font-size: 30rpx; font-weight: 700; color: #1a1c1c; line-height: 1.4; }
.pc-summary { font-size: 24rpx; color: #5e3f3a; line-height: 1.5; margin-top: 8rpx; }
.pc-tags { display: flex; gap: 10rpx; flex-wrap: wrap; margin-top: 12rpx; }
.pc-tag { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 8rpx; font-weight: 500; white-space: nowrap; }
.tag-money { background: #fef3c7; color: #705d00; }
.tag-where { background: #f3f3f3; color: #5e3f3a; }
.tag-deadline { background: #ffdad4; color: #a00000; }

/* 纯白变体卡片（图文混合） */
.policy-card-white {
  background: #fff;
  border-left: none;
  display: flex;
  gap: 20rpx;
  border: 2rpx solid #e2e2e2;
}
.policy-card-white .pc-thumb {
  width: 120rpx; height: 120rpx;
  border-radius: 12rpx;
  background: #eeeeee;
  flex-shrink: 0;
}

.empty-state { text-align: center; padding: 80rpx; color: #9ca3af; font-size: 28rpx; }

.loading-state { text-align: center; padding: 80rpx; color: #5e3f3a; }
.loading-spinner {
  width: 40rpx; height: 40rpx;
  border: 4rpx solid #e2e2e2;
  border-top: 4rpx solid var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 16rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
