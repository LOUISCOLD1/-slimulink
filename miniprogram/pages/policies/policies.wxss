.container { padding: 0 0 32rpx; }

.search-bar {
  margin: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.search-icon { font-size: 28rpx; }
.search-input { flex: 1; font-size: 28rpx; }

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 0;
}
.cat-item:active { opacity: 0.7; }
.cat-icon {
  width: 80rpx; height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.cat-name { font-size: 22rpx; color: #374151; font-weight: 500; }

.cat-gold { background: linear-gradient(135deg, #fef3c7, #fde68a); }
.cat-blue { background: linear-gradient(135deg, #dbeafe, #bfdbfe); }
.cat-purple { background: linear-gradient(135deg, #ede9fe, #ddd6fe); }
.cat-green { background: linear-gradient(135deg, #d1fae5, #a7f3d0); }
.cat-pink { background: linear-gradient(135deg, #ffe4e6, #fecdd3); }
.cat-sky { background: linear-gradient(135deg, #e0f2fe, #bae6fd); }
.cat-rose { background: linear-gradient(135deg, #fce7f3, #fbcfe8); }
.cat-gray { background: #f3f4f6; }

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 28rpx 12rpx;
}
.section-title { font-size: 28rpx; font-weight: 700; color: #064e3b; }
.section-clear { font-size: 24rpx; color: #059669; }

.policy-card {
  background: #fff;
  margin: 0 24rpx 12rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.policy-card:active { background: #f9fafb; }
.pc-title { font-size: 30rpx; font-weight: 600; color: #1f2937; margin-bottom: 8rpx; }
.pc-summary { font-size: 24rpx; color: #6b7280; line-height: 1.5; margin-bottom: 12rpx; }
.pc-tags { display: flex; gap: 10rpx; flex-wrap: wrap; }
.pc-tag { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 10rpx; font-weight: 500; }
.tag-money { background: #fef3c7; color: #92400e; }
.tag-where { background: #dbeafe; color: #1e40af; }

.empty-state { text-align: center; padding: 80rpx; color: #9ca3af; font-size: 28rpx; }

.loading-state {
  text-align: center;
  padding: 80rpx;
  color: #6b7280;
  font-size: 28rpx;
}
.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #e5e7eb;
  border-top: 4rpx solid #059669;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 16rpx;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
