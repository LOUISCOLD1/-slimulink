<view class="container">
  <!-- 搜索框 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="{{lang === 'zh' ? '搜索政策...' : 'ᠲᠥᠷᠥ ᠵᠢᠷᠤᠮ ᠬᠠᠢᠬᠤ...'}}"
      bindinput="onSearchInput" value="{{searchText}}" />
  </view>

  <!-- 分类九宫格 -->
  <view class="category-grid" wx:if="{{!searchText}}">
    <view class="cat-item" wx:for="{{categories}}" wx:key="key"
      bindtap="onCategoryTap" data-category="{{item.key}}">
      <view class="cat-icon {{item.colorClass}}">{{item.icon}}</view>
      <view class="cat-name">{{lang === 'zh' ? item.zh : item.mn}}</view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>{{lang === 'zh' ? '加载中...' : 'ᠠᠴᠢᠶᠠᠯᠠᠵᠤ ᠪᠠᠢᠨ᠎ᠠ...'}}</text>
  </view>

  <!-- 政策列表 -->
  <view wx:if="{{!loading}}">
    <!-- 热门政策 -->
    <view wx:if="{{!searchText && !activeCategory && hotPolicies.length > 0}}">
      <view class="section-header">
        <text class="section-title">🔥 {{lang === 'zh' ? '热门政策' : 'ᠬᠠᠯᠠᠭᠤᠨ ᠲᠥᠷᠥ ᠵᠢᠷᠤᠮ'}}</text>
      </view>
      <view class="policy-card" wx:for="{{hotPolicies}}" wx:key="id"
        bindtap="onPolicyTap" data-id="{{item.id}}">
        <view class="pc-header">
          <view class="pc-title">{{lang === 'zh' ? item.title_zh : (item.title_mn || item.title_zh)}}</view>
        </view>
        <view class="pc-summary">{{item.summary}}</view>
        <view class="pc-tags">
          <text class="pc-tag tag-money" wx:if="{{item.money}}">💰 {{item.money}}</text>
          <text class="pc-tag tag-where" wx:if="{{item.where}}">📍 {{item.where}}</text>
        </view>
      </view>
    </view>

    <!-- 筛选结果/全部 -->
    <view wx:if="{{searchText || activeCategory}}">
      <view class="section-header">
        <text class="section-title">{{activeCategory || (lang === 'zh' ? '搜索结果' : 'ᠬᠠᠢᠯᠲᠠ ᠶᠢᠨ ᠳᠦᠩ')}}</text>
        <text class="section-clear" bindtap="clearFilter" wx:if="{{activeCategory}}">{{lang === 'zh' ? '清除筛选' : 'ᠴᠡᠪᠡᠷᠯᠡᠬᠦ'}}</text>
      </view>
    </view>

    <view class="policy-card" wx:for="{{filteredPolicies}}" wx:key="id"
      bindtap="onPolicyTap" data-id="{{item.id}}" wx:if="{{searchText || activeCategory}}">
      <view class="pc-header">
        <view class="pc-title">{{lang === 'zh' ? item.title_zh : (item.title_mn || item.title_zh)}}</view>
      </view>
      <view class="pc-summary">{{item.summary}}</view>
      <view class="pc-tags">
        <text class="pc-tag tag-money" wx:if="{{item.money}}">💰 {{item.money}}</text>
        <text class="pc-tag tag-where" wx:if="{{item.where}}">📍 {{item.where}}</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{(searchText || activeCategory) && filteredPolicies.length === 0}}">
      <text>{{lang === 'zh' ? '暂无相关政策' : 'ᠬᠣᠯᠪᠣᠭᠳᠠᠬᠤ ᠲᠥᠷᠥ ᠵᠢᠷᠤᠮ ᠪᠠᠢᠬᠤ ᠦᠭᠡᠢ'}}</text>
    </view>
  </view>
</view>
