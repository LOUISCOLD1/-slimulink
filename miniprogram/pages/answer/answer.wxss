.question-card {
  border-left: 8rpx solid #2563EB;
}

.card-label {
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.question-text {
  font-weight: bold;
  line-height: 1.6;
}

.answer-card {
  border-left: 8rpx solid #059669;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.play-btn {
  background: #059669;
  color: white;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.play-btn:active {
  opacity: 0.8;
}

.answer-text {
  line-height: 1.8;
  white-space: pre-wrap;
}

.source-section {
  margin-top: 16rpx;
}

.source-label {
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.source-item {
  font-size: 26rpx;
  color: #6B7280;
  padding: 4rpx 0;
}

/* 操作按钮 */
.action-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  background: #2563EB;
  color: white;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: bold;
}

.action-btn:active {
  opacity: 0.8;
}

.action-phone {
  background: #059669;
}

.disclaimer {
  font-size: 24rpx;
  text-align: center;
  padding: 16rpx;
  line-height: 1.6;
}
