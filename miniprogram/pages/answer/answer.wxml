<!-- 问答结果页 -->
<view class="container">

  <!-- 你的问题 -->
  <view class="card question-card">
    <view class="card-label text-gray">🗣️ {{lang === 'mn' ? 'ᠴᠢᠨᠦ ᠠᠰᠠᠭᠤᠯᠲᠠ' : '你问的'}}</view>
    <view class="question-text text-xl">{{question}}</view>
  </view>

  <!-- AI回答 -->
  <view class="card answer-card">
    <view class="card-header">
      <view class="card-label">🤖 {{lang === 'mn' ? 'ᠲᠥᠷᠥ ᠵᠢᠷᠤᠮ ᠤᠨ ᠲᠤᠰᠠᠯᠠᠭᠴᠢ' : '政策助手'}}</view>
      <view class="play-btn" bindtap="playAnswer">
        {{isPlaying ? '⏸️' : '🔊'}} {{isPlaying ? (lang === 'mn' ? 'ᠵᠣᠭᠰᠣᠬᠤ' : '暂停') : (lang === 'mn' ? 'ᠲᠣᠭᠯᠠᠬᠤ' : '播放语音')}}
      </view>
    </view>
    <view class="answer-text text-lg">{{answer}}</view>

    <!-- 来源标注 -->
    <view class="source-section" wx:if="{{sources.length > 0}}">
      <view class="divider"></view>
      <view class="source-label text-gray">📄 {{lang === 'mn' ? 'ᠮᠡᠳᠡᠭᠡᠯᠡᠯ ᠤᠨ ᠡᠬᠢ ᠰᠤᠷᠪᠤᠯᠵᠢ' : '信息来源'}}</view>
      <view class="source-item" wx:for="{{sources}}" wx:key="index">
        {{item}}
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-row">
    <view class="action-btn" bindtap="askAgain">
      🎙️ {{lang === 'mn' ? 'ᠦᠷᠭᠦᠯᠵᠢᠯᠡᠨ ᠠᠰᠠᠭᠤᠬᠤ' : '继续提问'}}
    </view>
    <view class="action-btn action-phone" bindtap="callHotline">
      📞 {{lang === 'mn' ? '12345 ᠤᠲᠠᠰᠤᠳᠠᠬᠤ' : '拨打' + hotlinePhone}}
    </view>
  </view>

  <!-- 提示 -->
  <view class="disclaimer text-gray">
    {{lang === 'mn' ? 'ᠳᠡᠭᠡᠷᠡᠬᠢ ᠮᠡᠳᠡᠭᠡᠯᠡᠯ ᠵᠥᠪᠬᠡᠨ ᠯᠠᠪᠯᠠᠯᠲᠠ ᠪᠣᠯᠬᠤ ᠪᠥᠭᠡᠳ ᠣᠷᠣᠨ ᠨᠤᠲᠤᠭ ᠤᠨ ᠰᠢᠨ᠎ᠡ ᠲᠥᠷᠥ ᠵᠢᠷᠤᠮ ᠢᠶᠠᠷ ᠪᠠᠷᠢᠮᠲᠠ ᠪᠣᠯᠭᠠᠨ᠎ᠠ ᠤᠤ᠃ ᠠᠰᠠᠭᠤᠯᠲᠠ ᠪᠠᠢᠪᠠᠯ 12345 ᠤᠲᠠᠰᠤ ᠪᠠᠷ ᠯᠠᠪᠯᠠᠨ᠎ᠠ ᠤᠤ᠃' : '以上信息仅供参考，具体以当地最新政策为准。如有疑问，建议拨打政务热线' + hotlinePhone + '咨询。'}}
  </view>

</view>
