.container { padding: 0 0 32rpx; }

.new-chat-btn {
  background: linear-gradient(135deg, #059669, #047857);
  color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin: 24rpx 24rpx 20rpx;
  box-shadow: 0 4rpx 8rpx rgba(5, 150, 105, 0.2), 0 12rpx 32rpx rgba(5, 150, 105, 0.2);
  position: relative;
  overflow: hidden;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
/* 按钮上的微光扫过效果 */
.new-chat-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.15),
    transparent
  );
  animation: shimmer 3s ease-in-out infinite;
}
@keyframes shimmer {
  0% { left: -100%; }
  50% { left: 150%; }
  100% { left: 150%; }
}
.new-chat-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
  box-shadow: 0 2rpx 4rpx rgba(5, 150, 105, 0.15), 0 6rpx 16rpx rgba(5, 150, 105, 0.15);
}

.chat-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  margin: 0 24rpx 12rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04), 0 6rpx 16rpx rgba(0, 0, 0, 0.03);
  /* 左侧金色指示线 */
  border-left: 4rpx solid rgba(251, 191, 36, 0.4);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}
.chat-item:active {
  background: #fafffe;
  transform: scale(0.985);
}

.chat-icon { font-size: 40rpx; flex-shrink: 0; }
.chat-info { flex: 1; overflow: hidden; }
.chat-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.chat-preview {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-meta {
  flex-shrink: 0;
  text-align: right;
}
.chat-time {
  font-size: 22rpx;
  color: #9ca3af;
  letter-spacing: 1rpx;
}
.chat-badge {
  font-size: 20rpx;
  color: #059669;
  background: #ecfdf5;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  margin-top: 6rpx;
  display: inline-block;
  font-weight: 500;
}

.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #9ca3af; }
